# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME="URL Shortener"
APP_DEBUG=false
# Public base URL used to build short links (no trailing slash)
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=shortener
POSTGRES_PASSWORD=shortener
POSTGRES_DB=shortener
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional explicit DSN (overrides the parts above if set)
# DATABASE_URL=postgresql+asyncpg://shortener:shortener@postgres:5432/shortener

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Seconds a resolved code stays in cache
CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────────────────────────
# Rate limiting (sliding window, per client IP)
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ─────────────────────────────────────────────────────────────
# Short codes
# ─────────────────────────────────────────────────────────────
SHORTCODE_LENGTH=7
SHORTCODE_MAX_RETRIES=6
ALIAS_MIN_LENGTH=3
ALIAS_MAX_LENGTH=32

# ─────────────────────────────────────────────────────────────
# GeoIP (optional). Mount a MaxMind GeoLite2-City.mmdb to enable.
# Leave empty to gracefully skip geo resolution.
# ─────────────────────────────────────────────────────────────
GEOIP_DB_PATH=
